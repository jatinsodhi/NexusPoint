{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "MANAGER", "MEMBER"] },
        "teamId": { "type": "string", "description": "ID of the team the user belongs to" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Team": {
      "title": "Team",
      "description": "A team of users",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "adminId": { "type": "string", "description": "UID of the team admin" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "adminId"]
    },
    "Project": {
      "title": "Project",
      "description": "A project managed by a team",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teamId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "teamId"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "projectId": { "type": "string" },
        "assignedTo": { "type": "string", "description": "UID of the assigned user" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "projectId"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message in a team",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "teamId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "senderId", "teamId", "timestamp"]
    }
  },
  "firestore": {
    "users/{uid}": { "schema": "User", "description": "User profiles" },
    "teams/{teamId}": { "schema": "Team", "description": "Team details" },
    "projects/{projectId}": { "schema": "Project", "description": "Project details" },
    "tasks/{taskId}": { "schema": "Task", "description": "Task details" },
    "messages/{messageId}": { "schema": "Message", "description": "Chat messages" }
  }
}
