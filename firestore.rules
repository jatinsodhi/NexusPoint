rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeamMember(teamId) {
      return isAuthenticated() && getUserData().teamId == teamId;
    }

    function isManager() {
      let role = getUserData().role;
      return role == 'MANAGER' || role == 'ADMIN';
    }

    function isAdmin() {
      return getUserData().role == 'ADMIN' || (request.auth.token.email == "jatinsodhi222@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && request.resource.data.role == 'MEMBER'; // Default role
      allow update: if isOwner(uid) && request.resource.data.role == resource.data.role; // Can't change own role
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Anyone can create a team initially? Or maybe only admin. Let's say anyone for demo.
      allow update, delete: if isAdmin() || isOwner(resource.data.adminId);
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && isTeamMember(resource.data.teamId);
      allow create: if isAuthenticated() && isManager();
      allow update: if isAuthenticated() && isManager();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isManager();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && isTeamMember(resource.data.teamId);
      allow create: if isAuthenticated() && isTeamMember(request.resource.data.teamId);
      allow update, delete: if false; // Messages are immutable for now
    }
  }
}
